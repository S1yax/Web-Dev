            "url": {
              "raw": "{{BASE_URL}}/api/tasks/1/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks", "1", ""]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n    \"id\": 1,\n    \"title\": \"Updated Task\",\n    \"description\": \"Updated description\",\n    \"status\": \"in_progress\",\n    \"category\": null,\n    \"created_at\": \"2026-04-04T12:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/tasks/1/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks", "1", ""]
            }
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        }
      ]
    },
