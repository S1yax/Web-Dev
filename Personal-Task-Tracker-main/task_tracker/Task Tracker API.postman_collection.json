              "body": "{\n    \"id\": 2,\n    \"title\": \"New Task\",\n    \"description\": \"Task description\",\n    \"status\": \"todo\",\n    \"category\": 1,\n    \"created_at\": \"2026-04-04T12:00:00Z\"\n}"
